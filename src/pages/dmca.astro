---
import "../styles/global.css";
---

<html lang="en">

<head>

    <title>
        DMCA Policy | Passport Eligibility Checker
    </title>

    <meta
        name="description"
        content="DMCA Policy for Passport Eligibility Checker. Learn how copyright complaints and infringement notices are handled."
    />

</head>

<body class="bg-slate-50">

    <main class="max-w-6xl mx-auto px-6">

        <!-- Hero -->

        <section
            class="
                relative
                overflow-hidden
                py-24
                text-center
            "
        >

            <div
                class="
                    absolute
                    top-0
                    left-1/2
                    -translate-x-1/2
                    w-[500px]
                    h-[500px]
                    rounded-full
                    bg-blue-200/20
                    blur-3xl
                "
            ></div>

            <span
                class="
                    text-blue-600
                    font-semibold
                    uppercase
                    tracking-widest
                "
            >
                Legal Information
            </span>

            <h1
                class="
                    mt-4
                    text-5xl
                    font-bold
                    text-slate-900
                "
            >
                DMCA Policy
            </h1>

            <p
                class="
                    mt-6
                    text-xl
                    text-slate-600
                    max-w-3xl
                    mx-auto
                    leading-8
                "
            >
                We respect intellectual property
                rights and comply with applicable
                copyright laws and regulations.
            </p>

        </section>

        <!-- Copyright Policy -->

        <section
            class="
                bg-white
                rounded-3xl
                border
                border-slate-200
                p-10
                shadow-sm
            "
        >

            <h2
                class="
                    text-3xl
                    font-bold
                    text-slate-900
                "
            >
                Copyright Policy
            </h2>

            <p
                class="
                    mt-6
                    text-slate-600
                    leading-8
                "
            >
                Passport Eligibility Checker respects
                the intellectual property rights of
                content creators, copyright holders
                and third parties. We expect users
                of this website to do the same.
            </p>

            <p
                class="
                    mt-4
                    text-slate-600
                    leading-8
                "
            >
                If you believe that any material
                appearing on this website infringes
                your copyright, you may submit a
                copyright complaint for review.
            </p>

        </section>

        <!-- Reporting -->

        <section
            class="
                mt-10
                bg-white
                rounded-3xl
                border
                border-slate-200
                p-10
                shadow-sm
            "
        >

            <h2
                class="
                    text-3xl
                    font-bold
                    text-slate-900
                "
            >
                Reporting Copyright Infringement
            </h2>

            <p
                class="
                    mt-6
                    text-slate-600
                    leading-8
                "
            >
                To submit a copyright complaint,
                please provide sufficient details
                to help identify the copyrighted
                work and the allegedly infringing
                content.
            </p>

            <div
                class="
                    mt-8
                    grid
                    md:grid-cols-2
                    gap-6
                "
            >

                <div
                    class="
                        rounded-2xl
                        bg-slate-50
                        p-6
                    "
                >
                    Full name of copyright owner
                </div>

                <div
                    class="
                        rounded-2xl
                        bg-slate-50
                        p-6
                    "
                >
                    Contact information
                </div>

                <div
                    class="
                        rounded-2xl
                        bg-slate-50
                        p-6
                    "
                >
                    Description of copyrighted work
                </div>

                <div
                    class="
                        rounded-2xl
                        bg-slate-50
                        p-6
                    "
                >
                    URL or location of content
                </div>

            </div>

        </section>

        <!-- Counter Notification -->

        <section
            class="
                mt-10
                bg-white
                rounded-3xl
                border
                border-slate-200
                p-10
                shadow-sm
            "
        >

            <h2
                class="
                    text-3xl
                    font-bold
                    text-slate-900
                "
            >
                Counter Notification
            </h2>

            <p
                class="
                    mt-6
                    text-slate-600
                    leading-8
                "
            >
                If you believe that content was
                removed or disabled in error,
                you may submit a counter-notification
                explaining your position and
                supporting information.
            </p>

            <p
                class="
                    mt-4
                    text-slate-600
                    leading-8
                "
            >
                Each request will be reviewed
                carefully and handled according
                to applicable laws and policies.
            </p>

        </section>

        <!-- Review Process -->

        <section
            class="
                mt-10
                bg-white
                rounded-3xl
                border
                border-slate-200
                p-10
                shadow-sm
            "
        >

            <h2
                class="
                    text-3xl
                    font-bold
                    text-slate-900
                "
            >
                Review Process
            </h2>

            <p
                class="
                    mt-6
                    text-slate-600
                    leading-8
                "
            >
                Upon receiving a valid copyright
                complaint, we may investigate the
                matter and take appropriate action,
                including removal or restriction
                of access to the disputed content.
            </p>

            <p
                class="
                    mt-4
                    text-slate-600
                    leading-8
                "
            >
                We reserve the right to request
                additional information when needed
                to properly evaluate a claim.
            </p>

        </section>

        <!-- Contact -->

        <section
            class="
                mt-10
                bg-gradient-to-r
                from-blue-50
                via-white
                to-indigo-50
                border
                border-blue-100
                rounded-3xl
                p-10
            "
        >

            <h2
                class="
                    text-3xl
                    font-bold
                    text-slate-900
                "
            >
                DMCA Contact Information
            </h2>

            <p
                class="
                    mt-6
                    text-slate-600
                    leading-8
                "
            >
                Copyright related requests,
                notices and counter-notifications
                may be sent to:
            </p>

            <div
                class="
                    mt-6
                    rounded-2xl
                    bg-white
                    p-6
                    border
                "
            >

                <p
                    class="
                        font-semibold
                        text-slate-900
                    "
                >
                    support@yourdomain.com
                </p>

            </div>

        </section>

        <!-- CTA -->

        <section
            class="
                py-24
                text-center
            "
        >

            <h2
                class="
                    text-4xl
                    font-bold
                    text-slate-900
                "
            >
                Questions About Our Policies?
            </h2>

            <p
                class="
                    mt-4
                    text-lg
                    text-slate-600
                "
            >
                Visit our contact page for
                assistance and support.
            </p>

            <a
                href="/contact"
                class="
                    inline-block
                    mt-8
                    px-8
                    py-4
                    rounded-xl
                    bg-blue-600
                    text-white
                    font-semibold
                    hover:bg-blue-700
                    transition
                "
            >
                Contact Us
            </a>

        </section>

    </main>

</body>

</html>