---
import Navbar from "../components/Navbar.tsx";
import Footer from "../components/Footer";
import "../styles/global.css";
---

<html lang="en">

<head>

    <title>
        Page Not Found | Passport Eligibility Checker
    </title>

</head>

<body class="bg-slate-50">

    <Navbar />

    <main
        class="
            min-h-screen
            flex
            items-center
            justify-center
            px-6
        "
    >

        <div
            class="
                text-center
                max-w-2xl
            "
        >

            <div
                class="
                    text-8xl
                    font-bold
                    text-blue-600
                "
            >
                404
            </div>

            <h1
                class="
                    mt-6
                    text-5xl
                    font-bold
                    text-slate-900
                "
            >
                Page Not Found
            </h1>

            <p
                class="
                    mt-6
                    text-xl
                    text-slate-600
                    leading-8
                "
            >
                The page you are looking for
                may have been moved, deleted
                or never existed.
            </p>

            <a
                href="/"
                class="
                    inline-flex
                    mt-10
                    px-8
                    py-4
                    rounded-2xl
                    bg-blue-600
                    text-white
                    font-semibold
                    hover:bg-blue-700
                    transition
                "
            >
                Return To Home
            </a>

        </div>

    </main>

    <Footer />

</body>

</html>