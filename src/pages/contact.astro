---
import "../styles/global.css";
---

<html lang="en">

<head>

    <title>
        Contact Us | Passport Eligibility Checker
    </title>

    <meta
        name="description"
        content="Contact Passport Eligibility Checker for support, feedback, bug reports and general inquiries."
    />

</head>

<body class="bg-slate-50">

    <main class="max-w-6xl mx-auto px-6">

        <!-- Hero Section -->

        <section
            class="
                relative
                overflow-hidden
                py-24
                text-center
            "
        >

            <div
                class="
                    absolute
                    top-0
                    left-1/2
                    -translate-x-1/2
                    w-[500px]
                    h-[500px]
                    rounded-full
                    bg-blue-200/20
                    blur-3xl
                "
            ></div>

            <span
                class="
                    text-blue-600
                    font-semibold
                    uppercase
                    tracking-widest
                "
            >
                Contact Us
            </span>

            <h1
                class="
                    mt-4
                    text-5xl
                    font-bold
                    text-slate-900
                "
            >
                We're Here To Help
            </h1>

            <p
                class="
                    mt-6
                    text-xl
                    text-slate-600
                    max-w-3xl
                    mx-auto
                    leading-8
                "
            >
                Have questions, feedback or need
                assistance? Reach out to us and
                we'll do our best to help.
            </p>

        </section>

        <!-- Contact Cards -->

        <section
            class="
                grid
                md:grid-cols-3
                gap-6
            "
        >

            <div
                class="
                    bg-white
                    border
                    border-slate-200
                    rounded-3xl
                    p-8
                    shadow-sm
                "
            >

                <h3
                    class="
                        text-xl
                        font-bold
                        text-slate-900
                    "
                >
                    General Inquiries
                </h3>

                <p
                    class="
                        mt-4
                        text-slate-600
                        leading-7
                    "
                >
                    Questions about passport
                    eligibility verification,
                    website features and usage.
                </p>

            </div>

            <div
                class="
                    bg-white
                    border
                    border-slate-200
                    rounded-3xl
                    p-8
                    shadow-sm
                "
            >

                <h3
                    class="
                        text-xl
                        font-bold
                        text-slate-900
                    "
                >
                    Technical Support
                </h3>

                <p
                    class="
                        mt-4
                        text-slate-600
                        leading-7
                    "
                >
                    Report bugs, upload issues,
                    OCR extraction problems or
                    website related concerns.
                </p>

            </div>

            <div
                class="
                    bg-white
                    border
                    border-slate-200
                    rounded-3xl
                    p-8
                    shadow-sm
                "
            >

                <h3
                    class="
                        text-xl
                        font-bold
                        text-slate-900
                    "
                >
                    Feedback & Suggestions
                </h3>

                <p
                    class="
                        mt-4
                        text-slate-600
                        leading-7
                    "
                >
                    Share ideas, feature requests
                    and suggestions to improve
                    the verification experience.
                </p>

            </div>

        </section>

        <!-- Contact Form -->

        <section
            class="
                mt-12
                bg-white
                border
                border-slate-200
                rounded-3xl
                p-10
                shadow-sm
            "
        >

            <h2
                class="
                    text-3xl
                    font-bold
                    text-slate-900
                "
            >
                Send Us A Message
            </h2>

            <p
                class="
                    mt-3
                    text-slate-600
                "
            >
                We typically respond within
                24–48 business hours.
            </p>

            <form
                class="
                    mt-8
                    grid
                    gap-6
                "
            >

                <div
                    class="
                        grid
                        md:grid-cols-2
                        gap-6
                    "
                >

                    <input
                        type="text"
                        placeholder="Your Name"
                        class="
                            w-full
                            rounded-xl
                            border
                            border-slate-300
                            px-4
                            py-3
                            outline-none
                            focus:border-blue-500
                        "
                    />

                    <input
                        type="email"
                        placeholder="Email Address"
                        class="
                            w-full
                            rounded-xl
                            border
                            border-slate-300
                            px-4
                            py-3
                            outline-none
                            focus:border-blue-500
                        "
                    />

                </div>

                <input
                    type="text"
                    placeholder="Subject"
                    class="
                        w-full
                        rounded-xl
                        border
                        border-slate-300
                        px-4
                        py-3
                        outline-none
                        focus:border-blue-500
                    "
                />

                <textarea
                    rows="6"
                    placeholder="Your Message"
                    class="
                        w-full
                        rounded-xl
                        border
                        border-slate-300
                        px-4
                        py-3
                        outline-none
                        resize-none
                        focus:border-blue-500
                    "
                ></textarea>

                <button
                    type="submit"
                    class="
                        w-fit
                        px-8
                        py-4
                        rounded-xl
                        bg-blue-600
                        text-white
                        font-semibold
                        hover:bg-blue-700
                        transition
                    "
                >
                    Send Message
                </button>

            </form>

        </section>

        <!-- Support Information -->

        <section
            class="
                mt-12
                bg-gradient-to-r
                from-blue-50
                via-white
                to-indigo-50
                border
                border-blue-100
                rounded-3xl
                p-10
            "
        >

            <h2
                class="
                    text-3xl
                    font-bold
                    text-slate-900
                "
            >
                Support Information
            </h2>

            <div
                class="
                    mt-8
                    grid
                    md:grid-cols-2
                    gap-8
                "
            >

                <div>

                    <h3
                        class="
                            font-semibold
                            text-lg
                        "
                    >
                        Response Time
                    </h3>

                    <p
                        class="
                            mt-3
                            text-slate-600
                        "
                    >
                        Most inquiries are answered
                        within 24–48 business hours.
                    </p>

                </div>

                <div>

                    <h3
                        class="
                            font-semibold
                            text-lg
                        "
                    >
                        Support Email
                    </h3>

                    <p
                        class="
                            mt-3
                            text-slate-600
                        "
                    >
                        support@yourdomain.com
                    </p>

                </div>

            </div>

        </section>

        <!-- CTA -->

        <section
            class="
                py-24
                text-center
            "
        >

            <h2
                class="
                    text-4xl
                    font-bold
                    text-slate-900
                "
            >
                Need Passport Verification?
            </h2>

            <p
                class="
                    mt-4
                    text-lg
                    text-slate-600
                "
            >
                Return to the verification tool
                and check your documents instantly.
            </p>

            <a
                href="/"
                class="
                    inline-block
                    mt-8
                    px-8
                    py-4
                    rounded-xl
                    bg-blue-600
                    text-white
                    font-semibold
                    hover:bg-blue-700
                    transition
                "
            >
                Back To Tool
            </a>

        </section>

    </main>

</body>

</html>